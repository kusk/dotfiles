#!/bin/bash

if [ -f $HOME/.dmenurc ]; then
   source $HOME/.dmenurc
   DMENU="$DMENU -p 'MPD add'"
else
   DMENU="dmenu -p 'mpd' -i -nb '#000000' -nf '#ffffff' -fn '6x12' -sb '#000000' -sf '#17bbe3'"
fi

RESULTS=$( (mpc -q list Artist; mpc -q list Album) | eval $DMENU )
   if [ $? -eq 0 ]; then
      mpc -q clear
      mpc -q findadd Album "$RESULTS"
      mpc -q findadd Artist "$RESULTS"
      mpc -q play
   fi
