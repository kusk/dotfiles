#!/bin/sh

help()
{
   # Display Help
   echo "-h\tThis Menu"
   echo "-k\tInstalls for kali"
   echo "-u\tInstalls for Ubuntu"
   echo "-m\tInstalls for Linux without UI"
}

ui()
{
    echo "\e[1;37m[\e[1;33m+\e[1;37m] \e[0;0m Installing for Kali"
    echo "\e[1;37m[\e[1;33m+\e[1;37m] \e[0;0m Installing apts"
    sudo DEBIAN_FRONTEND=noninteractive apt-get -qq update   > /dev/null 2>&1
    sudo DEBIAN_FRONTEND=noninteractive apt-get -qq install awesome xfce4-terminal  fonts-fork-awesome fonts-font-awesome rofi suckless-tools arc-theme feh vlc numix-icon-theme-circle redshift  < /dev/null > /dev/null

    awesomewm_install
    fonts_install
    xfce4_terminal_install
    diverse_install
}

kali()
{
    minimal
    ui
    mkdir ~/tools
    sudo apt -qq install nuclei bloodhound bloodhound.py  > /dev/null 2>&1
    sudo pip install mitm6  > /dev/null 2>&1
    sudo python3 -m pip install coercer  > /dev/null 2>&1
    sudo mkdir /share
    cd ~/tools
    git clone https://github.com/dirkjanm/krbrelayx  > /dev/null 2>&1
    wget https://github.com/michenriksen/aquatone/releases/download/v1.7.0/aquatone_linux_amd64_1.7.0.zip   > /dev/null 2>&1
    unzip aquatone_linux_amd64_1.7.0.zip
    sudo mv aquatone /usr/sbin/
    rm -rf README.md LICENSE.txt aquatone_linux_amd64_1.7.0.zip
}

ubuntu()
{
    echo "Install for Ubuntu"
    minimal
}

minimal()
{
    echo "\e[1;37m[\e[1;33m+\e[1;37m] \e[0;0m Running minimal install"
    sudo_install
    
    echo "\e[1;37m[\e[1;33m+\e[1;37m] \e[0;0m Installing minimal apts"
    sudo DEBIAN_FRONTEND=noninteractive apt-get -qq update   > /dev/null 2>&1
    sudo DEBIAN_FRONTEND=noninteractive apt-get -qq install git apt-transport-https open-vm-tools open-vm-tools-desktop htop tmux zsh nmap curl vim python3-pip < /dev/null > /dev/null

    prezto_install
    fzf_install
    vim_install
    tmux_install
    rm -rf ~/Billeder ~/Dokumenter ~/Musik ~/Offentligt ~/Skabeloner ~/Videoklip

}


sudo_install()
{
    echo "\e[1;37m[\e[1;33m+\e[1;37m] \e[0;0m Adding $USER to sudoers"
    echo '$USER ALL=(ALL:ALL) NOPASSWD: ALL' | sudo tee -a /etc/sudoers > /dev/null
}

fzf_install()
{
    echo "\e[1;37m[\e[1;33m+\e[1;37m] \e[0;0m Installing fzf"
    git clone --quiet --depth 1 https://github.com/junegunn/fzf.git ~/.fzf > /dev/null
    ln -s ~/.dotfiles/fzf.zsh ~/.fzf.zsh
    sudo usermod -s /usr/bin/zsh $USER   > /dev/null 2>&1
}

prezto_install()
{
    echo "\e[1;37m[\e[1;33m+\e[1;37m] \e[0;0m Installing prezto"
    git clone --quiet --recursive https://github.com/sorin-ionescu/prezto.git "${ZDOTDIR:-$HOME}/.zprezto" > /dev/null
    ln -s ~/.zprezto/runcoms/zlogin ~/.zlogin
    ln -s ~/.zprezto/runcoms/zlogout ~/.zlogout
    ln -s ~/.zprezto/runcoms/zpreztorc ~/.zpreztorc
    ln -s ~/.zprezto/runcoms/zprofile ~/.zprofile
    ln -s ~/.zprezto/runcoms/zshenv ~/.zshenv
    rm -rf ~/.zshrc
    ln -s ~/.dotfiles/zshrc ~/.zshrc
    ln -s ~/.dotfiles/p10k.zsh ~/.p10k.zsh 
}

vim_install()
{
    echo "\e[1;37m[\e[1;33m+\e[1;37m] \e[0;0m vim"
    ln -s ~/.dotfiles/vimrc ~/.vimrc
}

tmux_install()
{
    echo "\e[1;37m[\e[1;33m+\e[1;37m] \e[0;0m Tmux setup"
    ln -s ~/.dotfiles/tmux.conf ~/.tmux.conf
    git clone --quiet https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm  >/dev/null
    mkdir ~/.tmux-powerline
    git clone --quiet https://github.com/erikw/tmux-powerline.git ~/.tmux-powerline >/dev/null
}

fonts_install()
{
    echo "\e[1;37m[\e[1;33m+\e[1;37m] \e[0;0m Deploying patched fonts"
    git clone --quiet https://github.com/powerline/fonts ~/.powerline_fonts >/dev/null
    cd ~/.powerline_fonts
    sh install.sh  > /dev/null 2>&1
    cd ..
    rm -rf ~/.powerline_fonts
}


xfce4_terminal_install()
{
    echo "\e[1;37m[\e[1;33m+\e[1;37m] \e[0;0m Deploying xfce4-terminal"
    xfconf-query -c xfwm4 -p /general/theme -s "Aluminum"
    xfconf-query -c xsettings -p /Net/ThemeName -s "Arc-Darker"
}

awesomewm_install()
{
    echo "\e[1;37m[\e[1;33m+\e[1;37m] \e[0;0m AwesomeWM setup"
    mkdir ~/.config/awesome 
    cd ~/.config/awesome
    git clone --quiet --recurse-submodules --remote-submodules --depth 1 -j 2 https://github.com/lcpz/awesome-copycats.git >/dev/null
    mv -bv awesome-copycats/{*,.[^.]*} ~/.config/awesome; rm -rf awesome-copycats >/dev/null
    ln -s ~/.dotfiles/rc.lua ~/.config/awesome/rc.lua
    cd
}

diverse_install()
{
    
    echo "\e[1;37m[\e[1;33m+\e[1;37m] \e[0;0m Deploying XFCE4 themes/Quicktile"
    mkdir ~/.ssh
    ln -s ~/.dotfiles/themes ~/.themes
    mkdir -p ~/.config/xfce4/terminal/
    cp  -rf ~/.dotfiles/xfce4/terminalrc ~/.config/xfce4/terminal/
    git clone https://github.com/arcticicestudio/nord-xfce-terminal ~/.nord-xfce-terminal
    cd ~/.nord-xfce-terminal
    ./install.sh
    cd
}

while getopts ":hkucm" option; do
   case $option in
      h) # display Help
         help
         exit;;
      k)
        kali
        exit;;
      u)
        ubuntu
        exit;;
      m)
        minimal
        exit;;
        
   esac
done
