#!/bin/sh
echo "[+] Adding a to sudoers"
echo "a ALL=(ALL:ALL) NOPASSWD: ALL" | sudo tee -a /etc/sudoers > /dev/null

echo "[+] Installing apts"
sudo DEBIAN_FRONTEND=noninteractive apt-get install -qq git apt-transport-https rofi arc-theme htop tmux feh vlc zsh nmap curl numix-icon-theme-circle redshift vim python3-pip filezilla < /dev/null > /dev/null
echo "[+] Gitting dotfiles"
git clone --quiet http://github.com/kusk/dotfiles ~/.dotfiles > /dev/null


echo "[+] Creating dirs and symlinks"
echo "[+] Tmux setup"
ln -s ~/.dotfiles/tmux.conf ~/.tmux.conf
git clone --quiet https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm  >/dev/null


echo "[+] Deploying patched fonts"
cd /tmp
git clone --quiet https://github.com/powerline/fonts >/dev/null
cd /tmp/fonts
sh install.sh  >/dev/null


echo "[+] Deploying XFCE4 themes/Quicktile"
mkdir ~/.ssh
ln -s ~/.dotfiles/ssh/config ~/.ssh/config
ln -s ~/.dotfiles/themes ~/.themes
cp  -rf ~/.dotfiles/xfce4/terminalrc ~/.config/xfce4/terminal/
xfconf-query -c xfwm4 -p /general/theme -s "Aluminum"

echo "[+] Installing SublimeText3"
wget -qO - https://download.sublimetext.com/sublimehq-pub.gpg | sudo apt-key -qq add -
echo "deb https://download.sublimetext.com/ apt/stable/" | sudo tee /etc/apt/sources.list.d/sublime-text.list
sudo apt-get -qq update >/dev/null
sudo DEBIAN_FRONTEND=noninteractive apt-get install -qq sublime-text  < /dev/null > /dev/null

echo "Done!"
echo "[+] Install spacevim"
echo "url -sLf https://spacevim.org/install.sh | bash"
