execute pathogen#infect()
syntax on
set mouse=a
set number
filetype plugin indent on
map <C-f> :NERDTreeToggle<CR>
let NERDTreeShowHidden=1
let g:airline_powerline_fonts=1
set background=dark
colorscheme solarized

map  <C-m> :tabn<CR>
map  <C-n> :tabp<CR>
map  <C-w> :tabnew<CR>
map  <C-q> :tabclose<CR>
